# =============================================================================
# Apex Financial Event Store — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection URL for the event store.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/apex_financial

# PostgreSQL connection URL used by the test suite.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/apex_financial_test

# -----------------------------------------------------------------------------
# Field-Level Encryption (PII)
# -----------------------------------------------------------------------------
# AES-256-GCM key for encrypting applicant_name and applicant_id in event payloads.
# Generate with:
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Leave unset to disable encryption (plaintext storage).
FIELD_ENCRYPTION_KEY=

# Previous key — set during key rotation so old ciphertext can still be decrypted.
# Remove once all events have been re-encrypted with the new key.
FIELD_ENCRYPTION_KEY_OLD=

# -----------------------------------------------------------------------------
# Authentication & Rate Limiting
# -----------------------------------------------------------------------------
# Set to "true" to enable bearer-token auth and per-agent rate limiting.
ENABLE_AUTH=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
