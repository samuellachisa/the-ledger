# =============================================================================
# Apex Financial Event Store — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/apex_financial
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/apex_financial_test

# Connection pool sizing
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# Startup retry (wait for postgres to be ready)
DB_STARTUP_RETRIES=10
DB_STARTUP_RETRY_DELAY_SECONDS=2.0

# SSL mode: require | verify-ca | verify-full | (empty = disabled)
DB_SSL=

# Read replica for load distribution (optional)
DB_READ_URL=

# -----------------------------------------------------------------------------
# Field-Level Encryption (PII)
# -----------------------------------------------------------------------------
# Generate with: make generate-key
# Leave unset to disable encryption (plaintext storage).
FIELD_ENCRYPTION_KEY=

# Previous key — set during key rotation.
FIELD_ENCRYPTION_KEY_OLD=

# -----------------------------------------------------------------------------
# Authentication & Rate Limiting
# -----------------------------------------------------------------------------
ENABLE_AUTH=false

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log format: json (structured) | text (human-readable)
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# LangSmith / LangChain Tracing (optional)
# -----------------------------------------------------------------------------
# If you use LangChain/LangGraph callbacks elsewhere in your environment,
# these variables enable LangSmith trace ingestion.
#
# Note: this repo also has its own lightweight tracing in `src/observability/`,
# so LangSmith is optional and not required for correctness.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=the-ledger

# LangSmith SDK tracing for `langsmith.traceable` (used by BaseApexAgent real LLM path).
# Must be true to emit runs to LangSmith from `_call_llm` when USE_REAL_LLM=true.
LANGSMITH_TRACING_V2=false

# LangChain tracing toggles (common names).
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=

# Prometheus scrape port. Leave unset to disable the HTTP metrics endpoint.
METRICS_PORT=9090
METRICS_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Scheduled Jobs
# -----------------------------------------------------------------------------
# Enable background archival of old terminal streams
ENABLE_ARCHIVAL=false
ARCHIVAL_INTERVAL_HOURS=24
ARCHIVAL_AGE_DAYS=90

# Enable background enforcement of pending GDPR erasure requests
ENABLE_ERASURE_SCHEDULER=false
ERASURE_INTERVAL_MINUTES=60

# Enable background integrity monitor (hash chain verification)
ENABLE_INTEGRITY_MONITOR=true

# -----------------------------------------------------------------------------
# External Document Refiner (optional CLI)
# -----------------------------------------------------------------------------
# If you have a CLI that can extract financial facts, configure it here.
# When enabled, `document_refinery.pipeline.extract_financial_facts()` will
# call the CLI and parse JSON from stdout. If the CLI fails, the repo's
# deterministic python extractor is used as a fallback.
#
# Example:
# DOC_REFINER_USE_EXTERNAL=true
# DOC_REFINER_ENGINE_CMD="C:\path\to\doc-refiner-engine.exe"
# DOC_REFINER_TIMEOUT_SECONDS=30
DOC_REFINER_USE_EXTERNAL=false
DOC_REFINER_ENGINE_CMD=
DOC_REFINER_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# LLM (OpenAI-compatible chat/completions)
# -----------------------------------------------------------------------------
# Mode: stub (default, deterministic tests) | real (HTTP to LLM_BASE_URL).
LLM_MODE=stub

# Canonical real-LLM settings (preferred over provider-specific names below).
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1/chat/completions
LLM_MODEL=
LLM_TEMPERATURE=0.0
# Optional label for logs / LangSmith metadata.
LLM_PROVIDER=openai_compatible
# Optional LangSmith run name for traceable spans (default: llm.chat_completions).
# LLM_LANGSMITH_RUN_NAME=llm.chat_completions

# Legacy provider-specific aliases (used only if LLM_* above are empty).
GROQ_API_KEY=
GROQ_MODEL=
GROQ_BASE_URL=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Real LLM toggle (legacy; prefer LLM_MODE=real)
# -----------------------------------------------------------------------------
# When true, same as LLM_MODE=real if LLM_MODE is unset.
USE_REAL_LLM=false

# HTTP timeout for LLM calls.
LLM_TIMEOUT_SECONDS=60
