# =============================================================================
# Apex Financial Event Store — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/apex_financial
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/apex_financial_test

# Connection pool sizing
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# Startup retry (wait for postgres to be ready)
DB_STARTUP_RETRIES=10
DB_STARTUP_RETRY_DELAY_SECONDS=2.0

# SSL mode: require | verify-ca | verify-full | (empty = disabled)
DB_SSL=

# Read replica for load distribution (optional)
DB_READ_URL=

# -----------------------------------------------------------------------------
# Field-Level Encryption (PII)
# -----------------------------------------------------------------------------
# Generate with: make generate-key
# Leave unset to disable encryption (plaintext storage).
FIELD_ENCRYPTION_KEY=

# Previous key — set during key rotation.
FIELD_ENCRYPTION_KEY_OLD=

# -----------------------------------------------------------------------------
# Authentication & Rate Limiting
# -----------------------------------------------------------------------------
ENABLE_AUTH=false

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log format: json (structured) | text (human-readable)
LOG_FORMAT=json

# Prometheus scrape port. Leave unset to disable the HTTP metrics endpoint.
METRICS_PORT=9090
METRICS_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Scheduled Jobs
# -----------------------------------------------------------------------------
# Enable background archival of old terminal streams
ENABLE_ARCHIVAL=false
ARCHIVAL_INTERVAL_HOURS=24
ARCHIVAL_AGE_DAYS=90

# Enable background enforcement of pending GDPR erasure requests
ENABLE_ERASURE_SCHEDULER=false
ERASURE_INTERVAL_MINUTES=60

# Enable background integrity monitor (hash chain verification)
ENABLE_INTEGRITY_MONITOR=true
